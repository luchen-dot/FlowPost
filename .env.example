# FlowPost Environment Variables
# Copy to .env and fill in your API keys
# API Keys are stored in SQLite (Settings page), not here.
# This file is for reference only.

# CLAUDE_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# DEEPSEEK_API_KEY=...

# Server port (default: 3001)
PORT=3001
